# GitHub Git Attributes

# Auto detect text files and perform LF normalization
* text=auto

# Force Unix line endings for these files
*.py text eol=lf
*.jsx text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.sh text eol=lf
*.html text eol=lf
*.htm text eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.whl binary
*.mp4 binary
*.mov binary
*.avi binary
*.mp3 binary
*.wav binary
*.flac binary

# Linguist language overrides
*.css linguist-language=JavaScript
